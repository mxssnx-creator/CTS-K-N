# Local Wrangler/OpenNext runtime example. Copy to .dev.vars and replace every
# placeholder. Never commit .dev.vars or real credentials.
ADMIN_SECRET=replace_with_32_byte_random_admin_secret
CRON_SECRET=replace_with_32_byte_random_cron_secret
ENCRYPTION_KEY=replace_with_32_byte_random_encryption_key
JWT_SECRET=replace_with_32_byte_random_jwt_secret
REDIS_URL=redis://127.0.0.1:6379
NEXT_PUBLIC_APP_URL=http://127.0.0.1:8787
DEPLOYMENT_URL=http://127.0.0.1:8787

# Required for the Kilo Remote SSH Install tab. The owner must be a distinct,
# long-lived HTTPS CTS-K-N server. Its ADMIN_SECRET is used here as the proxy
# bearer secret.
REMOTE_INSTALL_OWNER_URL=https://owner.example.com
REMOTE_INSTALL_OWNER_SECRET=replace_with_owner_admin_secret
