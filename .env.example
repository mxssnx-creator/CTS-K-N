# ─────────────────────────────────────────────────────────────────────────────
# CTS-V Trading Engine — Environment Variables
#
# Copy this file to .env.development.local for local development.
# For local production smoke tests with `next start`, copy to .env.production.local.
# In hosted production (Vercel), set these in the Vercel project dashboard under
# Settings → Environment Variables.
#
# Required variables are marked [REQUIRED].
# Optional variables are marked [OPTIONAL] with their default shown.
# ─────────────────────────────────────────────────────────────────────────────


# ── Exchange API Credentials ──────────────────────────────────────────────────
# At least one exchange must be configured for the engine to place live orders.
# Live placement fails closed when credentials are absent; simulation requires
# an explicitly selected simulated/paper connection or FORCE_SIMULATED=1.
#
# PRODUCTION: Set these in Vercel Dashboard → Settings → Environment Variables
# Required for /api/trade-engine/quick-start to place REAL exchange orders.
# Without valid credentials, the engine runs in SIMULATION mode only.

# BingX (primary exchange, bingx-x01) - PRODUCTION MAINNET
BINGX_API_KEY=replace_me_bingx_api_key
BINGX_API_SECRET=replace_me_bingx_api_secret
# Official read-only quote origins; the app fails over and keeps the healthy
# host sticky. These never receive API credentials or order requests.
BINGX_PUBLIC_ORIGIN=https://open-api.bingx.com
BINGX_PUBLIC_FALLBACK_ORIGIN=https://open-api.bingx.pro

# Bybit (secondary exchange, bybit-x03)
BYBIT_API_KEY=replace_me_bybit_api_key
BYBIT_API_SECRET=replace_me_bybit_api_secret

# Pionex (optional exchange, pionex-x01)
PIONEX_API_KEY=replace_me_pionex_api_key
PIONEX_API_SECRET=replace_me_pionex_api_secret

# OrangeX (optional exchange, orangex-x01)
ORANGEX_API_KEY=replace_me_orangex_api_key
ORANGEX_API_SECRET=replace_me_orangex_api_secret


# ── Security ─────────────────────────────────────────────────────────────────

# Encryption key for sensitive data at rest (32+ random bytes, base64)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=                         # [REQUIRED in production]

# JWT secret for session tokens
# Generate: openssl rand -base64 32
JWT_SECRET=replace_me_jwt_secret

# Admin API secret for protected admin endpoints
ADMIN_SECRET=replace_me_admin_secret

# Shared bearer secret for the portable one-minute scheduler and cron routes.
# Generate: openssl rand -hex 32
CRON_SECRET=replace_me_with_at_least_16_random_characters  # [REQUIRED for external production scheduling]

# Redis inspection endpoint; requires ADMIN_SECRET bearer auth when enabled
REDIS_DEBUG_ENABLED=0                   # [OPTIONAL, default: disabled]


# ── Application ───────────────────────────────────────────────────────────────

# Public URL of the app (used for absolute URLs in emails etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3002  # [OPTIONAL, defaults to localhost:3002]

# NextAuth base URL (only if using NextAuth)
NEXTAUTH_URL=http://localhost:3002         # [OPTIONAL]

# Base URL contacted by `pnpm scheduler:minute` on serverless deployments.
SCHEDULER_BASE_URL=http://localhost:3002   # [REQUIRED for external scheduler process]


# ── Engine Control Flags ──────────────────────────────────────────────────────

# Set to "1" to force live exchange orders even in development
FORCE_LIVE=                             # [OPTIONAL, default: unset]

# Set to "1" to force simulated (paper) trading regardless of credentials
FORCE_SIMULATED=                        # [OPTIONAL, default: unset]

# Auto-start and continuity are enabled by default on a long-lived Node server.
# Disable them on stateless API/serverless workers; use one dedicated worker or
# the portable scheduler so a single runtime owns engine progression.
DISABLE_TRADE_ENGINE_AUTOSTART=         # [OPTIONAL, set "1" on passive API workers]
DISABLE_IN_PROCESS_CONTINUITY=          # [OPTIONAL, set "1" on serverless/passive workers]
DISABLE_TRADE_ENGINE_IN_PROCESS=        # [REQUIRED: "1" on serverless API workers]
CTS_DEPLOYMENT_RUNTIME=                 # [OPTIONAL, cloudflare-workers is set by wrangler.jsonc]

# Legacy browser indication polling is development-only by default. The server
# engine and minute scheduler own production continuity.
NEXT_PUBLIC_ENABLE_BROWSER_INDICATION_CRON= # [OPTIONAL diagnostic override]

# Disable cron-driven strategy execution in production (for debugging only)
DISABLE_PROD_CRON_STRATEGIES=           # [OPTIONAL, default: unset]

# Maximum time QuickStart waits for a production engine boot before returning
# a durable queued state. Values are clamped to 1-25s so the 35s UI request
# always retains at least 10s of headroom. Default: 18000ms.
QUICKSTART_ENGINE_BOOT_WAIT_MS=         # [OPTIONAL, default: 18000]


# ── Performance Tuning ────────────────────────────────────────────────────────

# Independent realtime symbols in flight. Contracts to 1 near RSS soft limit.
ENGINE_SYMBOL_CONCURRENCY=              # [OPTIONAL, default: 2, max: 4]

# Historic bootstrap symbols and continuous replay symbols in flight
PREHISTORIC_SYMBOL_CONCURRENCY=         # [OPTIONAL, default: 2, max: 4]
PREHISTORIC_REPLAY_SYMBOL_CONCURRENCY=  # [OPTIONAL, default: 1, max: 2]

# Total per-domain config budget, divided across concurrently active types
PREHISTORIC_CONFIG_CONCURRENCY=         # [OPTIONAL, default: 8, max: 16]
PREHISTORIC_CONFIG_TYPE_CONCURRENCY=    # [OPTIONAL, default: 4, max: 5]

# Independent indication Set keys/outcome groups written concurrently
INDICATION_SET_WRITE_CONCURRENCY=       # [OPTIONAL, default: 12, max: 24]
INDICATION_OUTCOME_CONCURRENCY=         # [OPTIONAL, default: 8, max: 20]
INDICATION_SET_READ_CONCURRENCY=        # [OPTIONAL, default: 12, max: 32]

# Base→Main→Real symbol graph and Preset optimizer worker pools
STRATEGY_FLOW_SYMBOL_CONCURRENCY=       # [OPTIONAL, default: 2 prod / 1 dev, max: 4]
PRESET_SYMBOL_CONCURRENCY=              # [OPTIONAL, default: 4, max: 8]
PRESET_CONFIG_SET_CONCURRENCY=          # [OPTIONAL, default: 2, max: 4]
PRESET_COMBINATION_CONCURRENCY=         # [OPTIONAL, default: 8, max: 20]
PRESET_OPTIMIZER_SYMBOL_CONCURRENCY=    # [OPTIONAL, default: 2, max: 4]

# Independent Base/Main/Real symbol groups and pseudo-position updates
BASE_POSITION_SYMBOL_CONCURRENCY=       # [OPTIONAL, default: 4, max: 8]
MAIN_POSITION_SYMBOL_CONCURRENCY=       # [OPTIONAL, default: 4, max: 8]
REAL_POSITION_CONCURRENCY=              # [OPTIONAL, default: 4, max: 8]
PSEUDO_POSITION_CONCURRENCY=            # [OPTIONAL, default: 12, max: 32]
POSITION_FLOW_READ_CONCURRENCY=         # [OPTIONAL, default: 12, max: 32; exchange mutations remain serial]

# Full-history fetches kept resident at once during cold bootstrap
MARKET_DATA_LOAD_CONCURRENCY=           # [OPTIONAL, default: 2, max: 6]

# Bounded realtime candle window and temporary historic chunk sizes
REALTIME_CANDLE_WINDOW=                 # [OPTIONAL, default: 300, range: 120-1200]
HISTORIC_CANDLE_CHUNK_SIZE=             # [OPTIONAL, default: 300, range: 100-1000]
HISTORIC_CHUNK_READ_BATCH=              # [OPTIONAL, default: 8, max: 32]
HISTORIC_CHUNK_WRITE_BATCH=             # [OPTIONAL, default: 12, max: 32]

# Cap the Main-stage axis sets ceiling (override for resource-constrained envs)
STRATEGY_MAIN_AXIS_SETS_CEILING=        # [OPTIONAL, default: 2000 prod / 500 dev]

# Cap the Real-stage safety ceiling
STRATEGY_REAL_SETS_CEILING=             # [OPTIONAL, default: 600 prod / 200 dev]

# Max milliseconds a live position is held before forced evaluation
MAX_POSITION_HOLD_MS=                   # [OPTIONAL, default: 86400000 (24h)]


# ── Storage ───────────────────────────────────────────────────────────────────

# Production/preview shared Redis [REQUIRED]
# Configure at least one shared Redis option for production/preview deployments:
#   - REDIS_URL
#   - KV_URL
#   - UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
#   - KV_REST_API_URL + KV_REST_API_TOKEN
# InlineLocalRedis lets a production UI/paper instance boot, but it is process-local,
# can reset on worker restart, and does not unlock real exchange order placement.
REDIS_URL=                              # [REQUIRED in production/preview unless another shared Redis option is set]
KV_URL=                                 # [REQUIRED in production/preview unless another shared Redis option is set]
UPSTASH_REDIS_REST_URL=                 # [REQUIRED with UPSTASH_REDIS_REST_TOKEN in production/preview unless another shared Redis option is set]
UPSTASH_REDIS_REST_TOKEN=replace_me_upstash_redis_rest_token
ALLOW_PROD_INLINE_REDIS=1              # [DEFAULT] keep InlineLocalRedis enabled in production/preview; set "0" to require shared Redis
ALLOW_INLINE_REDIS_LIVE_TRADING=       # [DANGEROUS local-only override; never use on serverless/multi-instance]

# Path to the Redis snapshot file (InlineLocalRedis persistence)
# Defaults to .v0-data/redis-snapshot.json relative to the project root
V0_REDIS_SNAPSHOT_PATH=                 # [OPTIONAL, dev/local InlineLocalRedis only]

# Path for automated backup exports
BACKUP_PATH=                            # [OPTIONAL]

# Number of symbols active in dev mode (overrides the default 1-symbol dev cap)
# Set to e.g. "10" to enable multi-symbol dev testing
V0_DEV_SYMBOL_COUNT=1                   # [OPTIONAL, default: 1]


# ── External Database (optional, replaces InlineLocalRedis) ───────────────────
# Only set these if you are using an external PostgreSQL / hosted database
# instead of the default file-based InlineLocalRedis store.

DATABASE_TYPE=                          # [OPTIONAL] "postgres" | "redis" | "local"
DATABASE_URL=                           # [OPTIONAL] PostgreSQL connection string
REMOTE_POSTGRES_URL=                    # [OPTIONAL] alternate Postgres URL
DB_PATH=                                # [OPTIONAL] SQLite file path (if using SQLite)


# ── Upstash/Vercel KV Redis REST (shared Redis option) ────────────────────────
# In production/preview, this pair is one valid shared Redis option when REDIS_URL/KV_URL/Upstash REST is not set.
KV_REST_API_URL=                        # [REQUIRED with KV_REST_API_TOKEN in production/preview unless another shared Redis option is set]
KV_REST_API_TOKEN=replace_me_kv_rest_api_token


# ── Vercel (set automatically by Vercel, do not set manually) ─────────────────
# VERCEL=1
# VERCEL_ENV=production | preview | development
# VERCEL_URL=<deployment-url>
