{
  "name": "cts-k-n",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=5632 --max-semi-space-size=256 --expose-gc' node node_modules/next/dist/bin/next build",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096 --max-semi-space-size=192 --expose-gc' node node_modules/next/dist/bin/next dev -p ${PORT:-3002}",
    "dev:debug": "node scripts/dev-debug.js",
    "dev:debug:verbose": "node scripts/dev-debug.js verbose",
    "quickstart": "node scripts/quickstart-live-trading.js",
    "autotest": "node scripts/autotest-drift.mjs",
    "test:quickstart-3": "node scripts/test-quickstart-3symbols.js",
    "test": "node scripts/smoke-routes-test.mjs",
    "test:unit": "jest --runInBand --detectOpenHandles --testPathPatterns=__tests__/unit --passWithNoTests",
    "test:integration": "jest --runInBand --detectOpenHandles --testPathPatterns=__tests__/integration --passWithNoTests",
    "test:e2e": "jest --runInBand --detectOpenHandles --testPathPatterns=__tests__/e2e --passWithNoTests",
    "test:all": "jest --runInBand --detectOpenHandles --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "start": "NODE_OPTIONS='--max-old-space-size=5632 --max-semi-space-size=256 --expose-gc' node node_modules/next/dist/bin/next start -H ${HOST:-0.0.0.0} -p ${PORT:-3002}",
    "vercel-build": "NODE_OPTIONS='--max-old-space-size=5632 --max-semi-space-size=256 --expose-gc' next build",
    "vercel-build-setup": "bash scripts/vercel-build-setup.sh",
    "post-deploy-verify": "bash scripts/post-deploy-verify.sh",
    "test:deployment-contract": "node scripts/verify-deployment-contract.mjs",
    "install:preflight": "bash scripts/install.sh --preflight-only --skip-system-packages",
    "kilo:preflight": "node scripts/kilo-deploy-preflight.mjs",
    "kilo:preflight:runtime": "KILO_REQUIRE_RUNTIME_ENV=1 node scripts/kilo-deploy-preflight.mjs",
    "kilo:build": "pnpm run kilo:preflight && node scripts/clean-opennext-output.mjs && opennextjs-cloudflare build",
    "kilo:preview": "pnpm run kilo:build && opennextjs-cloudflare preview",
    "kilo:preview:verify": "pnpm run kilo:build && node scripts/test-kilo-runtime.mjs",
    "kilo:dry-run": "pnpm run kilo:build && wrangler deploy --dry-run",
    "kilo:deploy": "node scripts/kilo-deploy.mjs",
    "kilo:verify": "CTS_DEPLOYMENT_RUNTIME=kilo-deploy REQUIRE_SHARED_PERSISTENCE=1 REQUIRE_FRESH_CONTINUITY=1 bash scripts/post-deploy-verify.sh",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "deploy:local": "vercel",
    "deploy:prod": "vercel --prod",
    "prebuild": "node scripts/remove-stray-bun-lock.mjs && node scripts/verify-source-syntax.mjs && node scripts/clean-next-dist.mjs",
    "prevercel-build": "node scripts/remove-stray-bun-lock.mjs && node scripts/verify-source-syntax.mjs && node scripts/clean-next-dist.mjs",
    "setup:github-cli": "bash scripts/setup-github-cli.sh",
    "maintain:github-origin": "bash scripts/maintain-github-origin.sh",
    "test:volatile-cleanup": "node scripts/verify-volatile-cleanup.mjs",
    "postbuild": "node scripts/normalize-next-env.mjs",
    "postvercel-build": "node scripts/normalize-next-env.mjs",
    "build:prod-parallel": "NEXT_DIST_DIR=.next-prod pnpm run build",
    "start:prod-parallel": "NEXT_DIST_DIR=.next-prod PORT=${PORT:-3003} pnpm run start",
    "test:quickstart-12": "node scripts/run-dev-preview-check.mjs",
    "test:dev-preview": "node scripts/run-dev-preview-check.mjs",
    "test:dev-soak-12": "node scripts/run-dev-preview-check.mjs",
    "test:stress-32": "NODE_OPTIONS='--expose-gc --max-old-space-size=1024' node scripts/stress-bingx-public-32.mjs",
    "test:stress-bingx-5": "BINGX_STRESS_SYMBOL_COUNT=5 BINGX_STRESS_TICKER_ROUNDS=3 NODE_OPTIONS='--expose-gc --max-old-space-size=1024' node scripts/stress-bingx-public-32.mjs",
    "test:prod-preview": "node scripts/run-prod-preview-check.mjs",
    "test:prod-preview:max": "node scripts/run-prod-preview-check.mjs --max-symbols",
    "test:prod-preview:verify": "node scripts/verify-prod-preview.mjs",
    "test:prod-ui:max": "node scripts/verify-prod-ui-max.mjs",
    "test:prod-soak": "node scripts/verify-prod-soak.mjs",
    "scheduler:minute": "node scripts/run-minute-scheduler.mjs",
    "scheduler:minute:once": "node scripts/run-minute-scheduler.mjs --once",
    "test:scheduler:minute": "node scripts/test-minute-scheduler.mjs",
    "test:kilo-runtime": "node scripts/test-kilo-runtime.mjs",
    "security:scan": "node scripts/scan-release-secrets.mjs",
    "docs:recreation": "node scripts/generate-recreation-manifests.mjs",
    "docs:recreation:verify": "node scripts/verify-recreation-manifests.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/run-managed-db-migrate.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
