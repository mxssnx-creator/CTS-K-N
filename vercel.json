{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/**": {
      "maxDuration": 30
    },
    "app/api/cron/**": {
      "maxDuration": 60
    },
    "app/api/engine/**": {
      "maxDuration": 60
    },
    "app/api/connections/*/progression/**": {
      "maxDuration": 45
    }
  },
  "installCommand": "corepack pnpm@10.28.1 install --frozen-lockfile",
  "buildCommand": "corepack pnpm@10.28.1 run vercel-build"
}
